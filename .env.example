# --- LLM：默认本机 Ollama（OpenAI 兼容接口）---
# 先安装 https://ollama.com 然后：ollama pull llama3.2
# OPENAI_MODEL 必须与 `ollama list` 中的名称一致（如 llama3.2、qwen2.5 等）
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=llama3.2

# --- 或：Google Gemini（免费额度见 [Google AI Studio](https://aistudio.google.com/apikey)）---
# 使用官方 OpenAI 兼容入口，与现有 /chat/completions 逻辑一致；Key 仅在后端使用，不要写进前端。
# GEMINI_API_KEY / GEMINI_MODEL 为可选别名，与 OPENAI_API_KEY / OPENAI_MODEL 等价（二选一即可）。
# GEMINI_API_KEY=你的_API_Key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-2.0-flash

# 若改用 OpenAI / Groq 等云端，改为例如：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# MemPalace：Chroma 目录（须与 bootstrap / mempalace mine 一致）
# 建议填本项目绝对路径，例如：
MEMPALACE_PALACE_PATH=/Users/you/Projects/spiritshell-ai-backend/data/palace

# RAG：可选 MemPalace wing 过滤
MEMPALACE_DEFAULT_WING=spiritshell

MEMORY_TOP_K=5
MEMORY_OPTIONAL=true

SAFETY_BLOCKLIST=

SPIRITSHELL_IDENTITY=你是灵壳 SpiritShell 的 AI 陪伴助手：温暖、克制、不替代真人；涉及医疗或紧急情况时建议联系真人或急救。
