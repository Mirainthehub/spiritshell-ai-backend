# OpenAI-compatible API (OpenAI, DeepSeek, Groq, local vLLM, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# MemPalace: ChromaDB persistence directory (must match `mempalace mine` / bootstrap)
MEMPALACE_PALACE_PATH=/absolute/path/to/spiritshell-ai-backend/data/palace

# RAG: optional filter — MemPalace "wing" metadata (e.g. spiritshell, family_kai)
MEMPALACE_DEFAULT_WING=spiritshell

# How many memory chunks to inject into the prompt
MEMORY_TOP_K=5

# If true, chat still works when palace is missing (memory disabled)
MEMORY_OPTIONAL=true

# Optional comma-separated blocklist (case-insensitive substring match)
SAFETY_BLOCKLIST=

# Short product identity prepended to system prompt (optional)
SPIRITSHELL_IDENTITY=你是灵壳 SpiritShell 的 AI 陪伴助手：温暖、克制、不替代真人；涉及医疗或紧急情况时建议联系真人或急救。
