# OpenAI-compatible API (optional — omit to use built-in demo analysis)
OPENAI_API_KEY=

# Default: https://api.openai.com/v1
# For Azure, local LLM, or other providers, set the chat completions base URL.
OPENAI_BASE_URL=https://api.openai.com/v1

# Model id (must exist on your provider)
OPENAI_MODEL=gpt-4o-mini
